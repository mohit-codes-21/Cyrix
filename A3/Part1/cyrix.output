Grammar

    0 $accept: translation_unit $end

    1 lambda_params: IDENTIFIER
    2              | lambda_params ',' IDENTIFIER

    3 lambda_expression: '(' ')' LAMBDA_ARROW expression
    4                  | '(' ')' LAMBDA_ARROW compound_statement
    5                  | '(' lambda_params ')' LAMBDA_ARROW expression
    6                  | '(' lambda_params ')' LAMBDA_ARROW compound_statement

    7 primary_expression: IDENTIFIER
    8                   | constant
    9                   | string
   10                   | '(' expression ')'
   11                   | generic_selection
   12                   | lambda_expression

   13 constant: I_CONSTANT
   14         | F_CONSTANT
   15         | ENUMERATION_CONSTANT

   16 enumeration_constant: IDENTIFIER

   17 string: STRING_LITERAL
   18       | FUNC_NAME

   19 generic_selection: GENERIC '(' assignment_expression ',' generic_assoc_list ')'

   20 generic_assoc_list: generic_association
   21                   | generic_assoc_list ',' generic_association

   22 generic_association: type_name ':' assignment_expression
   23                    | DEFAULT ':' assignment_expression

   24 postfix_expression: primary_expression
   25                   | postfix_expression '[' expression ']'
   26                   | postfix_expression '(' ')'
   27                   | postfix_expression '(' argument_expression_list ')'
   28                   | postfix_expression '.' IDENTIFIER
   29                   | postfix_expression PTR_OP IDENTIFIER
   30                   | postfix_expression SAFE_DOT IDENTIFIER
   31                   | postfix_expression INC_OP
   32                   | postfix_expression DEC_OP
   33                   | '(' type_name ')' '{' initializer_list '}'
   34                   | '(' type_name ')' '{' initializer_list ',' '}'

   35 argument_expression_list: assignment_expression
   36                         | argument_expression_list ',' assignment_expression

   37 unary_expression: postfix_expression
   38                 | INC_OP unary_expression
   39                 | DEC_OP unary_expression
   40                 | unary_operator cast_expression
   41                 | SIZEOF unary_expression
   42                 | SIZEOF '(' type_name ')'
   43                 | ALIGNOF '(' type_name ')'

   44 unary_operator: '&'
   45               | '*'
   46               | '+'
   47               | '-'
   48               | '~'
   49               | '!'

   50 cast_expression: unary_expression
   51                | '(' type_name ')' cast_expression

   52 power_expression: cast_expression
   53                 | cast_expression POW_OP power_expression

   54 multiplicative_expression: power_expression
   55                          | multiplicative_expression '*' power_expression
   56                          | multiplicative_expression '/' power_expression
   57                          | multiplicative_expression '%' power_expression

   58 additive_expression: multiplicative_expression
   59                    | additive_expression '+' multiplicative_expression
   60                    | additive_expression '-' multiplicative_expression

   61 shift_expression: additive_expression
   62                 | shift_expression LEFT_OP additive_expression
   63                 | shift_expression RIGHT_OP additive_expression

   64 relational_expression: shift_expression
   65                      | relational_expression '<' shift_expression
   66                      | relational_expression '>' shift_expression
   67                      | relational_expression LE_OP shift_expression
   68                      | relational_expression GE_OP shift_expression
   69                      | relational_expression TH_OP shift_expression

   70 equality_expression: relational_expression
   71                    | equality_expression EQ_OP relational_expression
   72                    | equality_expression NE_OP relational_expression

   73 and_expression: equality_expression
   74               | and_expression '&' equality_expression

   75 exclusive_or_expression: and_expression
   76                        | exclusive_or_expression '^' and_expression

   77 inclusive_or_expression: exclusive_or_expression
   78                        | inclusive_or_expression '|' exclusive_or_expression

   79 logical_and_expression: inclusive_or_expression
   80                       | logical_and_expression AND_OP inclusive_or_expression

   81 logical_or_expression: logical_and_expression
   82                      | logical_or_expression OR_OP logical_and_expression

   83 conditional_expression: logical_or_expression

   84 lhs_list: IDENTIFIER
   85         | lhs_list ',' IDENTIFIER

   86 rhs_list: assignment_expression
   87         | rhs_list ',' assignment_expression

   88 multi_assignment: lhs_list '=' rhs_list

   89 assignment_expression: conditional_expression
   90                      | unary_expression assignment_operator assignment_expression

   91 assignment_operator: '='
   92                    | MUL_ASSIGN
   93                    | DIV_ASSIGN
   94                    | MOD_ASSIGN
   95                    | ADD_ASSIGN
   96                    | SUB_ASSIGN
   97                    | LEFT_ASSIGN
   98                    | RIGHT_ASSIGN
   99                    | AND_ASSIGN
  100                    | XOR_ASSIGN
  101                    | OR_ASSIGN

  102 expression: assignment_expression
  103           | expression ',' assignment_expression

  104 constant_expression: conditional_expression

  105 var_init_list: var_init
  106              | var_init_list ',' var_init

  107 var_init: IDENTIFIER '=' assignment_expression

  108 var_declaration: VAR var_init_list ';'

  109 declaration: declaration_specifiers ';'
  110            | declaration_specifiers init_declarator_list ';'
  111            | static_assert_declaration
  112            | var_declaration

  113 declaration_specifiers: storage_class_specifier declaration_specifiers
  114                       | storage_class_specifier
  115                       | type_specifier declaration_specifiers
  116                       | type_specifier
  117                       | type_qualifier declaration_specifiers
  118                       | type_qualifier
  119                       | function_specifier declaration_specifiers
  120                       | function_specifier
  121                       | alignment_specifier declaration_specifiers
  122                       | alignment_specifier

  123 init_declarator_list: init_declarator
  124                     | init_declarator_list ',' init_declarator

  125 init_declarator: declarator '=' initializer
  126                | declarator

  127 storage_class_specifier: TYPEDEF
  128                        | EXTERN
  129                        | STATIC
  130                        | THREAD_LOCAL
  131                        | AUTO
  132                        | REGISTER

  133 type_specifier: VOID
  134               | CHAR
  135               | SHORT
  136               | INT
  137               | LONG
  138               | FLOAT
  139               | DOUBLE
  140               | SIGNED
  141               | UNSIGNED
  142               | BOOL
  143               | COMPLEX
  144               | IMAGINARY
  145               | atomic_type_specifier
  146               | struct_or_union_specifier
  147               | enum_specifier
  148               | TYPEDEF_NAME

  149 struct_or_union_specifier: struct_or_union '{' struct_declaration_list '}'
  150                          | struct_or_union IDENTIFIER '{' struct_declaration_list '}'
  151                          | struct_or_union IDENTIFIER

  152 struct_or_union: STRUCT
  153                | UNION

  154 struct_declaration_list: struct_declaration
  155                        | struct_declaration_list struct_declaration

  156 struct_declaration: specifier_qualifier_list ';'
  157                   | specifier_qualifier_list struct_declarator_list ';'
  158                   | static_assert_declaration

  159 specifier_qualifier_list: type_specifier specifier_qualifier_list
  160                         | type_specifier
  161                         | type_qualifier specifier_qualifier_list
  162                         | type_qualifier

  163 struct_declarator_list: struct_declarator
  164                       | struct_declarator_list ',' struct_declarator

  165 struct_declarator: ':' constant_expression
  166                  | declarator ':' constant_expression
  167                  | declarator

  168 enum_specifier: ENUM '{' enumerator_list '}'
  169               | ENUM '{' enumerator_list ',' '}'
  170               | ENUM IDENTIFIER '{' enumerator_list '}'
  171               | ENUM IDENTIFIER '{' enumerator_list ',' '}'
  172               | ENUM IDENTIFIER

  173 enumerator_list: enumerator
  174                | enumerator_list ',' enumerator

  175 enumerator: enumeration_constant '=' constant_expression
  176           | enumeration_constant

  177 atomic_type_specifier: ATOMIC '(' type_name ')'

  178 type_qualifier: CONST
  179               | RESTRICT
  180               | VOLATILE
  181               | ATOMIC

  182 function_specifier: INLINE
  183                   | NORETURN

  184 alignment_specifier: ALIGNAS '(' type_name ')'
  185                    | ALIGNAS '(' constant_expression ')'

  186 declarator: pointer direct_declarator
  187           | direct_declarator

  188 direct_declarator: IDENTIFIER
  189                  | '(' declarator ')'
  190                  | direct_declarator '[' ']'
  191                  | direct_declarator '[' '*' ']'
  192                  | direct_declarator '[' STATIC type_qualifier_list assignment_expression ']'
  193                  | direct_declarator '[' STATIC assignment_expression ']'
  194                  | direct_declarator '[' type_qualifier_list '*' ']'
  195                  | direct_declarator '[' type_qualifier_list STATIC assignment_expression ']'
  196                  | direct_declarator '[' type_qualifier_list assignment_expression ']'
  197                  | direct_declarator '[' type_qualifier_list ']'
  198                  | direct_declarator '[' assignment_expression ']'
  199                  | direct_declarator '(' parameter_type_list ')'
  200                  | direct_declarator '(' ')'
  201                  | direct_declarator '(' identifier_list ')'

  202 pointer: '*' type_qualifier_list pointer
  203        | '*' type_qualifier_list
  204        | '*' pointer
  205        | '*'

  206 type_qualifier_list: type_qualifier
  207                    | type_qualifier_list type_qualifier

  208 parameter_type_list: parameter_list ',' ELLIPSIS
  209                    | parameter_list

  210 parameter_list: normal_param_list
  211               | normal_param_list ',' default_param_list
  212               | default_param_list

  213 normal_param_list: normal_param
  214                  | normal_param_list ',' normal_param

  215 default_param_list: default_param
  216                   | default_param_list ',' default_param

  217 normal_param: declaration_specifiers declarator
  218             | declaration_specifiers abstract_declarator
  219             | declaration_specifiers

  220 default_param: declaration_specifiers declarator '=' assignment_expression

  221 identifier_list: IDENTIFIER
  222                | identifier_list ',' IDENTIFIER

  223 type_name: specifier_qualifier_list abstract_declarator
  224          | specifier_qualifier_list

  225 abstract_declarator: pointer direct_abstract_declarator
  226                    | pointer
  227                    | direct_abstract_declarator

  228 direct_abstract_declarator: '(' abstract_declarator ')'
  229                           | '[' ']'
  230                           | '[' '*' ']'
  231                           | '[' STATIC type_qualifier_list assignment_expression ']'
  232                           | '[' STATIC assignment_expression ']'
  233                           | '[' type_qualifier_list STATIC assignment_expression ']'
  234                           | '[' type_qualifier_list assignment_expression ']'
  235                           | '[' type_qualifier_list ']'
  236                           | '[' assignment_expression ']'
  237                           | direct_abstract_declarator '[' ']'
  238                           | direct_abstract_declarator '[' '*' ']'
  239                           | direct_abstract_declarator '[' STATIC type_qualifier_list assignment_expression ']'
  240                           | direct_abstract_declarator '[' STATIC assignment_expression ']'
  241                           | direct_abstract_declarator '[' type_qualifier_list assignment_expression ']'
  242                           | direct_abstract_declarator '[' type_qualifier_list STATIC assignment_expression ']'
  243                           | direct_abstract_declarator '[' type_qualifier_list ']'
  244                           | direct_abstract_declarator '[' assignment_expression ']'
  245                           | '(' ')'
  246                           | '(' parameter_type_list ')'
  247                           | direct_abstract_declarator '(' ')'
  248                           | direct_abstract_declarator '(' parameter_type_list ')'

  249 initializer: '{' initializer_list '}'
  250            | '{' initializer_list ',' '}'
  251            | assignment_expression

  252 initializer_list: designation initializer
  253                 | initializer
  254                 | initializer_list ',' designation initializer
  255                 | initializer_list ',' initializer

  256 designation: designator_list '='

  257 designator_list: designator
  258                | designator_list designator

  259 designator: '[' constant_expression ']'
  260           | '.' IDENTIFIER

  261 static_assert_declaration: STATIC_ASSERT '(' constant_expression ',' STRING_LITERAL ')' ';'

  262 statement: labeled_statement
  263          | compound_statement
  264          | expression_statement
  265          | selection_statement
  266          | iteration_statement
  267          | jump_statement

  268 labeled_statement: IDENTIFIER ':' statement
  269                  | CASE constant_expression ':' statement
  270                  | DEFAULT ':' statement

  271 compound_statement: '{' '}'
  272                   | '{' block_item_list '}'

  273 block_item_list: block_item
  274                | block_item_list block_item

  275 block_item: declaration
  276           | statement

  277 expression_statement: ';'
  278                     | expression ';'
  279                     | multi_assignment ';'

  280 match_statement: MATCH '(' expression ')' '{' case_list default_opt '}'

  281 case_list: case_list match_case
  282          | match_case

  283 match_case: CASE constant_expression ':' statement

  284 default_opt: ε
  285            | DEFAULT ':' statement

  286 selection_statement: IF '(' expression ')' statement ELSE statement
  287                    | IF '(' expression ')' statement
  288                    | SWITCH '(' expression ')' statement
  289                    | match_statement

  290 foreach_var: IDENTIFIER
  291            | type_specifier IDENTIFIER

  292 iteration_statement: WHILE '(' expression ')' statement
  293                    | DO statement WHILE '(' expression ')' ';'
  294                    | FOR '(' expression_statement expression_statement ')' statement
  295                    | FOR '(' expression_statement expression_statement expression ')' statement
  296                    | FOR '(' declaration expression_statement ')' statement
  297                    | FOR '(' declaration expression_statement expression ')' statement
  298                    | FOREACH '(' foreach_var IN expression ')' statement

  299 jump_statement: GOTO IDENTIFIER ';'
  300               | CONTINUE ';'
  301               | BREAK ';'
  302               | RETURN ';'
  303               | RETURN expression ';'

  304 translation_unit: external_declaration
  305                 | translation_unit external_declaration

  306 external_declaration: function_definition
  307                     | declaration

  308 function_definition: declaration_specifiers declarator declaration_list compound_statement
  309                    | declaration_specifiers declarator compound_statement

  310 declaration_list: declaration
  311                 | declaration_list declaration


