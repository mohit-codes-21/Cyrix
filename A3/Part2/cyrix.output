Grammar

    0 $accept: translation_unit $end

    1 lambda_params: IDENTIFIER
    2              | lambda_params ',' IDENTIFIER

    3 lambda_expression: FN '(' ')' LAMBDA_ARROW assignment_expression
    4                  | FN '(' ')' LAMBDA_ARROW compound_statement
    5                  | FN '(' lambda_params ')' LAMBDA_ARROW assignment_expression
    6                  | FN '(' lambda_params ')' LAMBDA_ARROW compound_statement

    7 primary_expression: IDENTIFIER
    8                   | constant
    9                   | string
   10                   | '(' expression ')'
   11                   | generic_selection
   12                   | lambda_expression

   13 constant: I_CONSTANT
   14         | F_CONSTANT
   15         | ENUMERATION_CONSTANT

   16 enumeration_constant: IDENTIFIER

   17 string: STRING_LITERAL
   18       | FUNC_NAME

   19 generic_selection: GENERIC '(' assignment_expression ',' generic_assoc_list ')'

   20 generic_assoc_list: generic_association
   21                   | generic_assoc_list ',' generic_association

   22 generic_association: type_name ':' assignment_expression
   23                    | DEFAULT ':' assignment_expression

   24 postfix_expression: primary_expression
   25                   | postfix_expression '[' expression ']'
   26                   | postfix_expression '(' ')'
   27                   | postfix_expression '(' argument_expression_list ')'
   28                   | postfix_expression '.' IDENTIFIER
   29                   | postfix_expression PTR_OP IDENTIFIER
   30                   | postfix_expression SAFE_DOT IDENTIFIER
   31                   | postfix_expression INC_OP
   32                   | postfix_expression DEC_OP
   33                   | '(' type_name ')' '{' initializer_list '}'
   34                   | '(' type_name ')' '{' initializer_list ',' '}'

   35 argument_expression_list: assignment_expression
   36                         | argument_expression_list ',' assignment_expression

   37 unary_expression: postfix_expression
   38                 | INC_OP unary_expression
   39                 | DEC_OP unary_expression
   40                 | unary_operator cast_expression
   41                 | SIZEOF unary_expression
   42                 | SIZEOF '(' type_name ')'
   43                 | ALIGNOF '(' type_name ')'

   44 unary_operator: '&'
   45               | '*'
   46               | '+'
   47               | '-'
   48               | '~'
   49               | '!'

   50 cast_expression: unary_expression
   51                | '(' type_name ')' cast_expression

   52 power_expression: cast_expression
   53                 | cast_expression POW_OP power_expression

   54 multiplicative_expression: power_expression
   55                          | multiplicative_expression '*' power_expression
   56                          | multiplicative_expression '/' power_expression
   57                          | multiplicative_expression '%' power_expression

   58 additive_expression: multiplicative_expression
   59                    | additive_expression '+' multiplicative_expression
   60                    | additive_expression '-' multiplicative_expression

   61 shift_expression: additive_expression
   62                 | shift_expression LEFT_OP additive_expression
   63                 | shift_expression RIGHT_OP additive_expression

   64 relational_expression: shift_expression
   65                      | relational_expression '<' shift_expression
   66                      | relational_expression '>' shift_expression
   67                      | relational_expression LE_OP shift_expression
   68                      | relational_expression GE_OP shift_expression
   69                      | relational_expression TH_OP shift_expression

   70 equality_expression: relational_expression
   71                    | equality_expression EQ_OP relational_expression
   72                    | equality_expression NE_OP relational_expression

   73 and_expression: equality_expression
   74               | and_expression '&' equality_expression

   75 exclusive_or_expression: and_expression
   76                        | exclusive_or_expression '^' and_expression

   77 inclusive_or_expression: exclusive_or_expression
   78                        | inclusive_or_expression '|' exclusive_or_expression

   79 logical_and_expression: inclusive_or_expression
   80                       | logical_and_expression AND_OP inclusive_or_expression

   81 logical_or_expression: logical_and_expression
   82                      | logical_or_expression OR_OP logical_and_expression

   83 conditional_expression: logical_or_expression

   84 assignment_expression: conditional_expression
   85                      | unary_expression assignment_operator assignment_expression

   86 assignment_operator: '='
   87                    | MUL_ASSIGN
   88                    | DIV_ASSIGN
   89                    | MOD_ASSIGN
   90                    | ADD_ASSIGN
   91                    | SUB_ASSIGN
   92                    | LEFT_ASSIGN
   93                    | RIGHT_ASSIGN
   94                    | AND_ASSIGN
   95                    | XOR_ASSIGN
   96                    | OR_ASSIGN

   97 expression: assignment_expression
   98           | expression ',' assignment_expression

   99 constant_expression: conditional_expression

  100 var_init_list: var_init
  101              | var_init_list ',' var_init

  102 var_init: IDENTIFIER '=' assignment_expression

  103 var_declaration: VAR var_init_list ';'

  104 declaration: declaration_specifiers ';'
  105            | declaration_specifiers init_declarator_list ';'
  106            | static_assert_declaration
  107            | var_declaration

  108 declaration_specifiers: storage_class_specifier declaration_specifiers
  109                       | storage_class_specifier
  110                       | type_specifier declaration_specifiers
  111                       | type_specifier
  112                       | type_qualifier declaration_specifiers
  113                       | type_qualifier
  114                       | function_specifier declaration_specifiers
  115                       | function_specifier
  116                       | alignment_specifier declaration_specifiers
  117                       | alignment_specifier

  118 init_declarator_list: init_declarator
  119                     | init_declarator_list ',' init_declarator

  120 init_declarator: declarator '=' initializer
  121                | declarator

  122 storage_class_specifier: TYPEDEF
  123                        | EXTERN
  124                        | STATIC
  125                        | THREAD_LOCAL
  126                        | AUTO
  127                        | REGISTER

  128 type_specifier: VOID
  129               | CHAR
  130               | SHORT
  131               | INT
  132               | LONG
  133               | FLOAT
  134               | DOUBLE
  135               | SIGNED
  136               | UNSIGNED
  137               | BOOL
  138               | COMPLEX
  139               | IMAGINARY
  140               | atomic_type_specifier
  141               | struct_or_union_specifier
  142               | enum_specifier
  143               | TYPEDEF_NAME

  144 struct_or_union_specifier: struct_or_union '{' struct_declaration_list '}'
  145                          | struct_or_union IDENTIFIER '{' struct_declaration_list '}'
  146                          | struct_or_union IDENTIFIER

  147 struct_or_union: STRUCT
  148                | UNION

  149 struct_declaration_list: struct_declaration
  150                        | struct_declaration_list struct_declaration

  151 struct_declaration: specifier_qualifier_list ';'
  152                   | specifier_qualifier_list struct_declarator_list ';'
  153                   | static_assert_declaration

  154 specifier_qualifier_list: type_specifier specifier_qualifier_list
  155                         | type_specifier
  156                         | type_qualifier specifier_qualifier_list
  157                         | type_qualifier

  158 struct_declarator_list: struct_declarator
  159                       | struct_declarator_list ',' struct_declarator

  160 struct_declarator: ':' constant_expression
  161                  | declarator ':' constant_expression
  162                  | declarator

  163 enum_specifier: ENUM '{' enumerator_list '}'
  164               | ENUM '{' enumerator_list ',' '}'
  165               | ENUM IDENTIFIER '{' enumerator_list '}'
  166               | ENUM IDENTIFIER '{' enumerator_list ',' '}'
  167               | ENUM IDENTIFIER

  168 enumerator_list: enumerator
  169                | enumerator_list ',' enumerator

  170 enumerator: enumeration_constant '=' constant_expression
  171           | enumeration_constant

  172 atomic_type_specifier: ATOMIC '(' type_name ')'

  173 type_qualifier: CONST
  174               | RESTRICT
  175               | VOLATILE

  176 function_specifier: INLINE
  177                   | NORETURN

  178 alignment_specifier: ALIGNAS '(' type_name ')'
  179                    | ALIGNAS '(' constant_expression ')'

  180 declarator: pointer direct_declarator
  181           | direct_declarator

  182 direct_declarator: IDENTIFIER
  183                  | '(' declarator ')'
  184                  | direct_declarator '[' ']'
  185                  | direct_declarator '[' '*' ']'
  186                  | direct_declarator '[' STATIC type_qualifier_list assignment_expression ']'
  187                  | direct_declarator '[' STATIC assignment_expression ']'
  188                  | direct_declarator '[' type_qualifier_list '*' ']'
  189                  | direct_declarator '[' type_qualifier_list STATIC assignment_expression ']'
  190                  | direct_declarator '[' type_qualifier_list assignment_expression ']'
  191                  | direct_declarator '[' type_qualifier_list ']'
  192                  | direct_declarator '[' assignment_expression ']'
  193                  | direct_declarator '(' parameter_type_list ')'
  194                  | direct_declarator '(' ')'
  195                  | direct_declarator '(' identifier_list ')'

  196 pointer: '*' type_qualifier_list pointer
  197        | '*' type_qualifier_list
  198        | '*' pointer
  199        | '*'

  200 type_qualifier_list: type_qualifier
  201                    | type_qualifier_list type_qualifier

  202 parameter_type_list: parameter_list ',' ELLIPSIS
  203                    | parameter_list

  204 parameter_list: param_declaration
  205               | parameter_list ',' param_declaration

  206 param_declaration: declaration_specifiers declarator
  207                  | declaration_specifiers abstract_declarator
  208                  | declaration_specifiers
  209                  | declaration_specifiers declarator '=' assignment_expression

  210 identifier_list: IDENTIFIER
  211                | identifier_list ',' IDENTIFIER

  212 type_name: specifier_qualifier_list abstract_declarator
  213          | specifier_qualifier_list

  214 abstract_declarator: pointer direct_abstract_declarator
  215                    | pointer
  216                    | direct_abstract_declarator

  217 direct_abstract_declarator: '(' abstract_declarator ')'
  218                           | '[' ']'
  219                           | '[' '*' ']'
  220                           | '[' STATIC type_qualifier_list assignment_expression ']'
  221                           | '[' STATIC assignment_expression ']'
  222                           | '[' type_qualifier_list STATIC assignment_expression ']'
  223                           | '[' type_qualifier_list assignment_expression ']'
  224                           | '[' type_qualifier_list ']'
  225                           | '[' assignment_expression ']'
  226                           | direct_abstract_declarator '[' ']'
  227                           | direct_abstract_declarator '[' '*' ']'
  228                           | direct_abstract_declarator '[' STATIC type_qualifier_list assignment_expression ']'
  229                           | direct_abstract_declarator '[' STATIC assignment_expression ']'
  230                           | direct_abstract_declarator '[' type_qualifier_list assignment_expression ']'
  231                           | direct_abstract_declarator '[' type_qualifier_list STATIC assignment_expression ']'
  232                           | direct_abstract_declarator '[' type_qualifier_list ']'
  233                           | direct_abstract_declarator '[' assignment_expression ']'
  234                           | '(' ')'
  235                           | '(' parameter_type_list ')'
  236                           | direct_abstract_declarator '(' ')'
  237                           | direct_abstract_declarator '(' parameter_type_list ')'

  238 initializer: '{' initializer_list '}'
  239            | '{' initializer_list ',' '}'
  240            | assignment_expression

  241 initializer_list: designation initializer
  242                 | initializer
  243                 | initializer_list ',' designation initializer
  244                 | initializer_list ',' initializer

  245 designation: designator_list '='

  246 designator_list: designator
  247                | designator_list designator

  248 designator: '[' constant_expression ']'
  249           | '.' IDENTIFIER

  250 static_assert_declaration: STATIC_ASSERT '(' constant_expression ',' STRING_LITERAL ')' ';'

  251 statement: labeled_statement
  252          | compound_statement
  253          | expression_statement
  254          | selection_statement
  255          | iteration_statement
  256          | jump_statement

  257 labeled_statement: IDENTIFIER ':' statement
  258                  | CASE constant_expression ':' statement
  259                  | DEFAULT ':' statement

  260 compound_statement: '{' '}'
  261                   | '{' block_item_list '}'

  262 block_item_list: block_item
  263                | block_item_list block_item

  264 block_item: declaration
  265           | statement

  266 expression_statement: ';'
  267                     | expression ';'

  268 match_statement: MATCH '(' expression ')' '{' case_list default_opt '}'

  269 case_list: case_list match_case
  270          | match_case

  271 match_case: CASE constant_expression ':' statement

  272 default_opt: ε
  273            | DEFAULT ':' statement

  274 selection_statement: IF '(' expression ')' statement ELSE statement
  275                    | IF '(' expression ')' statement
  276                    | SWITCH '(' expression ')' statement
  277                    | match_statement

  278 foreach_var: IDENTIFIER
  279            | type_specifier IDENTIFIER

  280 iteration_statement: WHILE '(' expression ')' statement
  281                    | DO statement WHILE '(' expression ')' ';'
  282                    | FOR '(' expression_statement expression_statement ')' statement
  283                    | FOR '(' expression_statement expression_statement expression ')' statement
  284                    | FOR '(' declaration expression_statement ')' statement
  285                    | FOR '(' declaration expression_statement expression ')' statement
  286                    | FOREACH '(' foreach_var IN expression ')' statement

  287 jump_statement: GOTO IDENTIFIER ';'
  288               | CONTINUE ';'
  289               | BREAK ';'
  290               | RETURN ';'
  291               | RETURN expression ';'

  292 translation_unit: external_declaration
  293                 | translation_unit external_declaration

  294 external_declaration: function_definition
  295                     | declaration

  296 function_definition: declaration_specifiers declarator declaration_list compound_statement
  297                    | declaration_specifiers declarator compound_statement

  298 declaration_list: declaration
  299                 | declaration_list declaration


